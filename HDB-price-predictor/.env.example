# Copy this file to .env and fill in your values
# .env is gitignored and never committed

# Telegram bot for feedback delivery
# 1. Create a bot via @BotFather on Telegram → /newbot
# 2. Copy the token it gives you
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram chat ID
# 1. Message your new bot anything
# 2. Open https://api.telegram.org/bot<TOKEN>/getUpdates in a browser
# 3. Copy the "id" field from "chat" in the response
TELEGRAM_CHAT_ID=your_chat_id_here
